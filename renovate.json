{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor"
  ],
  "labels": [
    "dependencies"
  ],
  "minimumReleaseAge": "3 days",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 20,
  "timezone": "Europe/Paris",
  "schedule": [
    "* 0-4,22-23 * * 1-5",
    "* * * * 0,6"
  ],
  "updateNotScheduled": false,
  "rebaseWhen": "conflicted",
  "commitMessageAction": "update",
  "commitMessagePrefix": "[tool] chore(deps):",
  "packageRules": [
    {
      "description": "Disable updates of images intentionally pinned to older versions for compatibility testing",
      "matchFileNames": [
        "^\\.drone\\.yml$"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "python"
      ],
      "matchCurrentVersion": "^3\\.(9|10|11|12)$",
      "enabled": false
    },
    {
      "description": "Disable updates of internal packages",
      "matchDatasources": [
        "maven"
      ],
      "enabled": false,
      "matchPackageNames": [
        "/^io\\.veriguard:/"
      ]
    },
    {
      "description": "swagger-annotations-jakarta must stay aligned with swagger-core embedded in springdoc-openapi 2.6.0. Versions > 2.2.43 cause /api-docs to return invalid schema. Requires Spring Boot 3.4+ and springdoc 2.7+ upgrade first.",
      "matchDatasources": ["maven"],
      "matchPackageNames": ["io.swagger.core.v3:swagger-annotations-jakarta"],
      "allowedVersions": "<=2.2.43",
      "enabled": true
    },
    {
      "description": "springdoc-openapi 2.7+ requires Spring Boot 3.4+ (uses LiteWebJarsResourceResolver from Spring Framework 6.2). Blocked until Spring Boot is upgraded from 3.3.7.",
      "matchDatasources": ["maven"],
      "matchPackageNames": ["/^org\\.springdoc:/"],
      "allowedVersions": "<=2.6.0",
      "enabled": true
    },
    {
      "matchDatasources": [
        "npm",
        "node-version"
      ],
      "commitMessagePrefix": "[frontend] chore(deps):"
    },
    {
      "matchDatasources": [
        "maven"
      ],
      "commitMessagePrefix": "[backend] chore(deps):"
    },
    {
      "matchPackageNames": [
        "react-apexcharts"
      ],
      "commitMessagePrefix": "[DANGER] [frontend] chore(deps):",
      "commitMessageSuffix": "(react-apexcharts has a yarn patch)"
    },
    {
      "matchPackageNames": [
        "html-to-image"
      ],
      "commitMessagePrefix": "[DANGER] [frontend] chore(deps):",
      "commitMessageSuffix": "(html-to-image has a yarn patch)"
    },
    {
      "groupName": "devDependencies (non-major)",
      "groupSlug": "dev-dependencies-non-major",
      "description": "Batch auto merge and batch on sunday morning, non-major update of dev dependencies once a week (Sunday 03:00)",
      "schedule": "* 3 * * 0",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "rebaseWhen": "always",
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "schedule": "* 5 * * 0",
    "rebaseWhen": "always",
    "automerge": false,
    "enabled": true
  }
}
