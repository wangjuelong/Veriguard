# Veriguard Development Environment Variables
# Copy this file to .env and update values as needed

# PostgreSQL Configuration
POSTGRES_USER=veriguard
POSTGRES_PASSWORD=veriguard

# pgAdmin Configuration
PGADMIN_USER=admin@veriguard.io
PGADMIN_PASSWORD=admin

# veriguard API, e.g. for XTM Composer
VERIGUARD_ADMIN_TOKEN=
XTM_COMPOSER_ID=

# veriguard URL used for XTM Composer, for macOS and Windows, use http://host.docker.internal:8080,
# for Linux, use http://localhost:8080
VERIGUARD_URL=