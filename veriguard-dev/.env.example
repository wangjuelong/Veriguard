# Veriguard Development Environment Variables
# Copy this file to .env and update values as needed

# PostgreSQL Configuration
POSTGRES_USER=veriguard
POSTGRES_PASSWORD=veriguard

# pgAdmin Configuration
PGADMIN_USER=admin@veriguard.io
PGADMIN_PASSWORD=admin

# veriguard API, e.g. for XTM Composer
VERIGUARD_ADMIN_TOKEN=
XTM_COMPOSER_ID=

# veriguard URL used for XTM Composer, for macOS and Windows, use http://host.docker.internal:8080,
# for Linux, use http://localhost:8080
VERIGUARD_URL=

# -----------------------------------------------------------------------------
# SOC Elastic connector (PRD §2.4 攻击编排, spec §4.4)
# -----------------------------------------------------------------------------
# Dev API 通过 IntelliJ 或 `mvn spring-boot:run` 从宿主机起，不在本 compose 内。
# 想让 dev API 拿到这几个变量，可以 `set -a; source veriguard-dev/.env` 后再起 mvn。
# 默认 enabled=false：未填时 ElasticSocConnector 不会实例化，dev 不会因 SOC 失联而退出。
# 启用步骤见 docs/参考资料/Veriguard二开落地说明.md "七、启用 SOC connector"。

VERIGUARD_SOC_ELASTIC_ENABLED=false
VERIGUARD_SOC_ELASTIC_URL=
VERIGUARD_SOC_ELASTIC_API_KEY=

# Optional overrides (留空走代码默认值)
# VERIGUARD_SOC_ELASTIC_ALERT_INDEX=.alerts-security.alerts-*
# VERIGUARD_SOC_ELASTIC_DETECTION_RULES_API=/api/detection_engine/rules/_find
# VERIGUARD_SOC_ELASTIC_QUERY_TIMEOUT_SECONDS=10
# VERIGUARD_SOC_ELASTIC_RULES_CACHE_TTL_SECONDS=300