# Veriguard root docker-compose env vars
# Copy this file to .env (next to docker-compose.yml) and fill in real values.
# Only variables consumed by `docker-compose.yml` belong here. Dev infra
# variables (POSTGRES_USER, PGADMIN_USER, ...) live in `veriguard-dev/.env`.

# -----------------------------------------------------------------------------
# SOC Elastic connector (PRD §2.4 攻击编排, spec §4.4)
# -----------------------------------------------------------------------------
# 默认 enabled=false：未填凭证时 ElasticSocConnector 不会被实例化，
# 攻击编排会在 SOC 状态页显示 "未配置"，不会因连不上 Elastic 而启动失败。
# 启用步骤见 docs/参考资料/Veriguard二开落地说明.md "七、启用 SOC connector"。

VERIGUARD_SOC_ELASTIC_ENABLED=false
VERIGUARD_SOC_ELASTIC_URL=
VERIGUARD_SOC_ELASTIC_API_KEY=

# Optional overrides (留空走代码默认值)
# VERIGUARD_SOC_ELASTIC_ALERT_INDEX=.alerts-security.alerts-*
# VERIGUARD_SOC_ELASTIC_DETECTION_RULES_API=/api/detection_engine/rules/_find
# VERIGUARD_SOC_ELASTIC_QUERY_TIMEOUT_SECONDS=10
# VERIGUARD_SOC_ELASTIC_RULES_CACHE_TTL_SECONDS=300
